<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Message Detail - Pharmacy</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
  <style>
    .fhir-json {
      max-height: 400px;
      overflow-y: auto;
      font-size: 0.75rem;
      background-color: #f8f9fa;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-dark bg-success">
    <div class="container">
      <a class="navbar-brand" href="/">
        <i class="bi bi-capsule me-2"></i>Pharmacy System
      </a>
    </div>
  </nav>

  <div class="container mt-4">
    <a href="/" class="btn btn-outline-success mb-3"><i class="bi bi-arrow-left me-1"></i>Back to Inbox</a>

    <div class="card shadow-sm">
      <div class="card-header bg-success text-white">
        <h5 class="mb-0">
          <% if (message.eventType === 'document') { %>
            <i class="bi bi-file-earmark-pdf me-2"></i>Document Transfer
          <% } else if (message.eventType === 'communicationrequest') { %>
            <i class="bi bi-chat-left-dots me-2"></i>Communication Request
          <% } else if (message.eventType === 'communication') { %>
            <i class="bi bi-chat-text me-2"></i>Communication
          <% } else { %>
            <i class="bi bi-envelope me-2"></i>Message
          <% } %>
          from <%= message.sourceName %>
        </h5>
      </div>
      <div class="card-body">
        <table class="table table-borderless">
          <tr>
            <th style="width:180px">Bundle ID</th>
            <td><code><%= message.bundleId %></code></td>
          </tr>
          <tr>
            <th>Event Type</th>
            <td><span class="badge bg-success"><%= message.eventType %></span></td>
          </tr>
          <tr>
            <th>Timestamp</th>
            <td><%= new Date(message.timestamp).toLocaleString('de-AT') %></td>
          </tr>
          <tr>
            <th>Source</th>
            <td><%= message.sourceName %><% if (message.sourceEndpoint) { %> (<code><%= message.sourceEndpoint.address %></code>)<% } %></td>
          </tr>
          <% if (message.patient) { %>
          <tr>
            <th>Patient</th>
            <td>
              <strong><%= message.patient.name %></strong>
              <% if (message.patient.birthDate) { %> | Born: <%= message.patient.birthDate %><% } %>
              <% if (message.patient.gender) { %> | <%= message.patient.gender %><% } %>
            </td>
          </tr>
          <% } %>
        </table>

        <% if (message.documents.length > 0) { %>
          <h6 class="mt-4"><i class="bi bi-file-earmark-pdf text-danger me-1"></i>Documents</h6>
          <div class="list-group mb-3">
            <% message.documents.forEach(function(doc) { %>
              <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <strong><%= doc.title %></strong>
                    <% if (doc.type) { %><br><small class="text-muted">Type: <%= doc.type %></small><% } %>
                    <% if (doc.category) { %> | <small class="text-muted">Category: <%= doc.category %></small><% } %>
                  </div>
                  <% if (doc.hasPdf) { %>
                    <a href="/message/<%= message.id %>/pdf/<%= doc.id %>" class="btn btn-sm btn-outline-danger" target="_blank">
                      <i class="bi bi-file-earmark-pdf me-1"></i>View PDF
                    </a>
                  <% } %>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>

        <% if (message.communications.length > 0) { %>
          <h6 class="mt-4"><i class="bi bi-chat-text text-info me-1"></i>Communications</h6>
          <% message.communications.forEach(function(comm) { %>
            <div class="card mb-2">
              <div class="card-body">
                <% if (comm.text) { %>
                  <p class="mb-0"><%= comm.text %></p>
                <% } else { %>
                  <p class="mb-0 text-muted">(No text content)</p>
                <% } %>
              </div>
            </div>
          <% }); %>
        <% } %>

        <% if (message.communicationRequests.length > 0) { %>
          <h6 class="mt-4"><i class="bi bi-chat-left-dots text-primary me-1"></i>Communication Requests</h6>
          <% message.communicationRequests.forEach(function(cr) { %>
            <div class="card mb-2">
              <div class="card-body">
                <span class="badge bg-info mb-2">Status: <%= cr.status %></span>
                <% if (cr.text) { %>
                  <p class="mb-0"><%= cr.text %></p>
                <% } else { %>
                  <p class="mb-0 text-muted">(No text content)</p>
                <% } %>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>
    </div>

    <!-- FHIR Bundle JSON (collapsible) -->
    <% if (message.rawBundle) { %>
    <div class="card shadow-sm mt-3">
      <div class="card-header bg-white d-flex justify-content-between align-items-center"
           style="cursor:pointer" data-bs-toggle="collapse" data-bs-target="#fhirBundleCollapse"
           aria-expanded="false" aria-controls="fhirBundleCollapse">
        <div>
          <h6 class="mb-0"><i class="bi bi-code-square me-1"></i>FHIR Bundle (JSON)</h6>
          <small class="text-muted">Full ATMessagingBundle as received via Matrix</small>
        </div>
        <i class="bi bi-chevron-down"></i>
      </div>
      <div class="collapse" id="fhirBundleCollapse">
        <div class="card-body p-0">
          <pre class="fhir-json m-0 p-3"><code><%- JSON.stringify(message.rawBundle, null, 2).replace(/</g, '&lt;').replace(/>/g, '&gt;') %></code></pre>
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
